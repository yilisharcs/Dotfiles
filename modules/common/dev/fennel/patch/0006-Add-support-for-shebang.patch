From 41e8d59394255f7f9a169ce0fbeb7b7427d633f2 Mon Sep 17 00:00:00 2001
From: yilisharcs <yilisharcs@gmail.com>
Date: Fri, 19 Jun 2026 09:13:54 -0300
Subject: [PATCH 6/7] Add support for shebang

---
 fnlfmt.fnl        | 14 ++++++++++++--
 test.fnl          |  3 ++-
 tests/shebang.fnl |  6 ++++++
 3 files changed, 20 insertions(+), 3 deletions(-)
 create mode 100644 tests/shebang.fnl

diff --git a/fnlfmt.fnl b/fnlfmt.fnl
index e1cc885..64affe8 100644
--- a/fnlfmt.fnl
+++ b/fnlfmt.fnl
@@ -457,12 +457,21 @@ When f returns a truthy value, recursively walks the children."
             "-" io.stdin
             _ (or (io.open filename :r) (abort filename)))
         original (f:read :*all)
-        parser (-> (fennel.stringStream original)
+        shebang (if (original:match "^#!")
+                  (let [nl (original:find "\n")]
+                    (or (and nl (original:sub 1 nl))
+                        (.. original "\n"))))
+        source (if shebang (original:sub (+ (length shebang) 1)) original)
+        parser (-> (fennel.stringStream source)
                    (fennel.parser filename
                                   {:comments (not no-comments)
                                    :plugins [{: parse-form :versions ["1.5.1"]}]}))
         out []]
     (f:close)
+    (when shebang
+      (let [lead (source:match "^\n*")]
+        (for [_ 1 (length lead)]
+          (table.insert out ""))))
     (var (skip-next? prev-ast) false)
     (each [ok? ast parser]
       (assert ok? ast)
@@ -483,6 +492,7 @@ When f returns a truthy value, recursively walks the children."
       (set prev-ast ast))
     (table.insert out "")
     (let [formatted (table.concat out "\n")]
-      (values formatted (not= formatted original)))))
+      (values (if shebang (.. shebang formatted) formatted)
+              (not= (if shebang (.. shebang formatted) formatted) original)))))
 
 {: fnlfmt : format-file :version "0.3.3-dev"}
diff --git a/test.fnl b/test.fnl
index 66376d1..34cc9f7 100644
--- a/test.fnl
+++ b/test.fnl
@@ -14,7 +14,8 @@
               :macro
               :if
               :lambda
-              :multiline])
+              :multiline
+              :shebang])
 
 (var pass 0)
 
diff --git a/tests/shebang.fnl b/tests/shebang.fnl
new file mode 100644
index 0000000..4fe8afb
--- /dev/null
+++ b/tests/shebang.fnl
@@ -0,0 +1,6 @@
+#!/usr/bin/env fennel
+
+(local hello 12)
+
+(fn abc []
+  (print :hello-world))
-- 
