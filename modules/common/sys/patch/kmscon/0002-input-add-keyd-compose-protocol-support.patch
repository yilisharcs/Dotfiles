+/*
+ * keyd compose table
+ *
+ * keyd encodes Unicode codepoints as 3-digit base-36 sequences preceded by
+ * KEY_CANCEL (evdev 223). The XCompose file maps each line index to a
+ * Unicode character. We parse it at startup to build a lookup table.
+ */
+
+#define KEYD_COMPOSE_LEADER KEY_CANCEL
+#define KEYD_TABLE_SIZE 35000
+
+static int keyd_code_to_digit(unsigned int code)
+{
+	switch (code) {
+	case KEY_1: return 1;
+	case KEY_2: return 2;
+	case KEY_3: return 3;
+	case KEY_4: return 4;
+	case KEY_5: return 5;
+	case KEY_6: return 6;
+	case KEY_7: return 7;
+	case KEY_8: return 8;
+	case KEY_9: return 9;
+	case KEY_0: return 0;
+	case KEY_A: return 10;
+	case KEY_B: return 11;
+	case KEY_C: return 12;
+	case KEY_D: return 13;
+	case KEY_E: return 14;
+	case KEY_F: return 15;
+	case KEY_G: return 16;
+	case KEY_H: return 17;
+	case KEY_I: return 18;
+	case KEY_J: return 19;
+	case KEY_K: return 20;
+	case KEY_L: return 21;
+	case KEY_M: return 22;
+	case KEY_N: return 23;
+	case KEY_O: return 24;
+	case KEY_P: return 25;
+	case KEY_Q: return 26;
+	case KEY_R: return 27;
+	case KEY_S: return 28;
+	case KEY_T: return 29;
+	case KEY_U: return 30;
+	case KEY_V: return 31;
+	case KEY_W: return 32;
+	case KEY_X: return 33;
+	case KEY_Y: return 34;
+	case KEY_Z: return 35;
+	default:    return -1;
+	}
+}
+
+void uxkb_keyd_table_init(struct input *input)
+{
+	const char *path;
+	char *home;
+	FILE *f;
+	char *line;
+	size_t len;
+	size_t idx;
+	int qstart, qend;
+	uint32_t cp;
+	uint32_t *table;
+
+	path = getenv("XCOMPOSEFILE");
+	if (path && *path) {
+		f = fopen(path, "r");
+		if (f)
+			goto parsed;
+	}
+
+	home = getenv("HOME");
+	if (home && *home) {
+		char buf[4096];
+		snprintf(buf, sizeof(buf), "%s/.XCompose", home);
+		f = fopen(buf, "r");
+		if (f)
+			goto parsed;
+	}
+
+	log_debug("no XCompose file found, keyd compose disabled");
+	return;
+
+parsed:
+	table = calloc(KEYD_TABLE_SIZE, sizeof(uint32_t));
+	if (!table) {
+		fclose(f);
+		return;
+	}
+
+	line = NULL;
+	len = 0;
+	idx = 0;
+
+	while (idx < KEYD_TABLE_SIZE && getline(&line, &len, f) != -1) {
+		/* find first and last double-quote */
+		qstart = -1;
+		qend = -1;
+		for (size_t i = 0; line[i]; i++) {
+			if (line[i] == '"') {
+				if (qstart < 0)
+					qstart = i;
+				qend = i;
+			}
+		}
+
+		if (qstart >= 0 && qend > qstart + 1) {
+			/*
+			 * Decode the UTF-8 sequence between quotes into a
+			 * single Unicode codepoint. We only handle up to
+			 * 4-byte sequences (U+0000..U+10FFFF).
+			 */
+			unsigned char *s = (unsigned char *)&line[qstart + 1];
+			unsigned char *end = (unsigned char *)&line[qend];
+			cp = 0;
+
+			if (s < end) {
+				if (*s < 0x80) {
+					cp = *s++;
+				} else if ((*s & 0xE0) == 0xC0) {
+					cp = *s++ & 0x1F;
+					cp = (cp << 6) | (*s++ & 0x3F);
+				} else if ((*s & 0xF0) == 0xE0) {
+					cp = *s++ & 0x0F;
+					cp = (cp << 6) | (*s++ & 0x3F);
+					cp = (cp << 6) | (*s++ & 0x3F);
+				} else if ((*s & 0xF8) == 0xF0) {
+					cp = *s++ & 0x07;
+					cp = (cp << 6) | (*s++ & 0x3F);
+					cp = (cp << 6) | (*s++ & 0x3F);
+					cp = (cp << 6) | (*s++ & 0x3F);
+				}
+			}
+
+			if (cp)
+				table[idx] = cp;
+		}
+
+		idx++;
+	}
+
+	free(line);
+	fclose(f);
+
+	input->keyd_table = table;
+	input->keyd_table_size = idx;
+	log_debug("loaded keyd compose table: %zu entries", idx);
+}
+
+void uxkb_keyd_table_destroy(struct input *input)
+{
+	free(input->keyd_table);
+	input->keyd_table = NULL;
+	input->keyd_table_size = 0;
+}
+
 static void timer_event(struct ev_timer *timer, uint64_t num, void *data)
 {
 	struct input_dev *dev = data;
@@ -398,8 +557,21 @@ static void uxkb_dev_repeat(struct input_dev *dev, unsigned int state)
 	ev_timer_update(dev->repeat_timer, &spec);
 }
 
+static void emit_keyd_event(struct input_dev *dev, uint32_t cp)
+{
+	dev->event.keycode = KEYD_COMPOSE_LEADER;
+	dev->event.ascii = (cp < 128) ? cp : 0;
+	dev->event.mods = 0;
+	dev->event.num_syms = 1;
+	dev->event.keysyms[0] = xkb_utf32_to_keysym(cp);
+	dev->event.codepoints[0] = cp;
+	dev->event.handled = false;
+	shl_hook_call(dev->input->key_hook, dev->input, &dev->event);
+}
+
 int uxkb_dev_process(struct input_dev *dev, uint16_t key_state, uint16_t code)
 {
+	struct input *input = dev->input;
 	struct xkb_state *state;
 	struct xkb_compose_state *compose_state;
 	xkb_keycode_t keycode;
@@ -412,6 +584,45 @@ int uxkb_dev_process(struct input_dev *dev, uint16_t key_state, uint16_t code)
 	if (key_state == KEY_REPEATED)
 		return -ENOKEY;
 
+	/*
+	 * keyd compose protocol: KEY_CANCEL (223) is the compose leader,
+	 * followed by 3 base-36 digit key presses. we intercept these at
+	 * the evdev level before xkbcommon translation.
+	 */
+	if (input->keyd_table && dev->keyd_collecting) {
+		if (key_state != KEY_PRESSED)
+			/* key release while collecting: suppress */
+			return -ENOKEY;
+
+		int d = keyd_code_to_digit(code);
+		if (d < 0) {
+			/* fall through non-digit press */
+			dev->keyd_collecting = false;
+			goto keyd_done;
+		}
+
+		dev->keyd_buf[dev->keyd_idx++] = d;
+		if (dev->keyd_idx < 3)
+			return -ENOKEY;
+
+		dev->keyd_collecting = false;
+		uint32_t idx = dev->keyd_buf[0] * 1296 + dev->keyd_buf[1] * 36 + dev->keyd_buf[2];
+		if (idx < input->keyd_table_size && input->keyd_table[idx]) {
+			uxkb_dev_resize_event(dev, 1);
+			emit_keyd_event(dev, input->keyd_table[idx]);
+			return 0;
+		}
+		return -ENOKEY;
+	}
+
+	if (input->keyd_table && key_state == KEY_PRESSED && code == KEYD_COMPOSE_LEADER) {
+		dev->keyd_collecting = true;
+		dev->keyd_idx = 0;
+		return -ENOKEY;
+	}
+
+keyd_done:
+
 	state = dev->state;
 	compose_state = dev->compose_state;
 	keycode = code + EVDEV_KEYCODE_OFFSET;
