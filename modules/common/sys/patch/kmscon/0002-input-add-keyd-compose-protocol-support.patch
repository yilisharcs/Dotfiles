diff --git a/src/input/input.c b/src/input/input.c
index 65c1d6f..c552e4b 100644
--- a/src/input/input.c
+++ b/src/input/input.c
@@ -523,6 +523,47 @@ int input_set_keymap(struct input *input, const char *model, const char *layout,
 			      compose_file_len);
 }
 
+SHL_EXPORT
+void input_load_keyd_table(struct input *input)
+{
+	if (!input)
+		return;
+
+	uxkb_keyd_table_init(input);
+}
+
+SHL_EXPORT
+int input_update_keymap(struct input *input, const char *model, const char *layout,
+			const char *variant, const char *options)
+{
+	struct shl_dlist *iter;
+	struct input_dev *dev;
+
+	if (input->ctx) {
+		shl_dlist_for_each(iter, &input->devices)
+		{
+			dev = shl_dlist_entry(iter, struct input_dev, list);
+			if (dev->capabilities & DEVICE_HAS_KEYS) {
+				input_sleep_dev(dev);
+				input_exit_keyboard(dev);
+			}
+		}
+	}
+	uxkb_keyd_table_destroy(input);
+	uxkb_desc_destroy(input);
+	uxkb_desc_init(input, model, layout, variant, options, NULL, NULL, NULL, 0);
+	shl_dlist_for_each(iter, &input->devices)
+	{
+		dev = shl_dlist_entry(iter, struct input_dev, list);
+		if (dev->capabilities & DEVICE_HAS_KEYS) {
+			input_init_keyboard(dev);
+			if (input->awake)
+				input_wake_up_dev(dev);
+		}
+	}
+	return 0;
+}
+
 SHL_EXPORT
 void input_set_conf(struct input *input, unsigned int repeat_delay, unsigned int repeat_rate,
 		    bool mouse_enabled)
@@ -565,6 +606,7 @@ void input_unref(struct input *input)
 		input_free_dev(dev);
 	}
 
+	uxkb_keyd_table_destroy(input);
 	uxkb_desc_destroy(input);
 	shl_hook_free(input->key_hook);
 	shl_hook_free(input->pointer_hook);
